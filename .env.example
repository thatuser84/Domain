# NOTE: groq api keys are per-account now (set from /settings after signing in), not here.

# Model id. llama-3.3-70b-versatile is the best balance of smart + loose for roleplay.
# other options: llama-3.1-8b-instant (faster/dumber), openai/gpt-oss-120b (smarter but more buttoned-up)
GROQ_MODEL=llama-3.3-70b-versatile

# Flask secret (anything random, only matters for session cookies)
FLASK_SECRET=change-me-to-something-random

# Max tokens per reply
MAX_TOKENS=700

# Temperature - higher = wilder/more creative, lower = more consistent
TEMPERATURE=1.0

# Supabase project — used for both the postgres database and auth (signup/login)
# Project settings -> API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moderation checker — OpenAI-compatible endpoint, optional (leave MODERATION_API_KEY blank to
# disable it entirely — it fails open / no-ops with no key set).
MODERATION_BASE_URL=https://api.freemodel.dev/v1
MODERATION_API_KEY=
MODERATION_MODEL=gpt-5.4-mini

# Accounts in this list skip moderation entirely (saves credits). Comma-separated emails.
STAFF_EMAILS=

# The owner account — gets an "owner" badge and unconditional true-private (every thread encrypted
# at rest, no random draw, no trust-week wait). Single email, not a list.
OWNER_EMAIL=

# True-private threads: message content is encrypted at rest with this key. Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key means every true-private thread's history becomes permanently undecryptable.
TRUE_PRIVATE_ENCRYPTION_KEY=
TRUE_PRIVATE_CHANCE=0.25
